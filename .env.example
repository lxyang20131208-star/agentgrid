# AgentGrid configuration — copy to .env and adjust.

# --- Coordinator ---
# Port the coordinator server listens on.
AGENTGRID_PORT=7420
# Path to the SQLite database file used by the coordinator.
AGENTGRID_DB=agentgrid.sqlite
# Credits granted to each new account on signup (bootstraps the economy).
AGENTGRID_SIGNUP_GRANT=10000
# Platform fee taken from each settled job, as a fraction (0 = no fee).
AGENTGRID_PLATFORM_FEE=0

# --- Client / Worker ---
# URL of the coordinator to connect to.
AGENTGRID_URL=http://localhost:7420
# API key for this account (obtain via `agentgrid register`).
AGENTGRID_API_KEY=

# --- Worker ---
# Comma-separated adapters this worker offers. Leave blank to auto-detect.
AGENTGRID_ADAPTERS=
# Permission mode passed to coding agents that support it (e.g. Claude Code).
AGENTGRID_PERMISSION_MODE=acceptEdits
# Price multiplier — buyers pay measuredCost * this. 1 = at cost, <1 undercuts.
AGENTGRID_PRICE_MULTIPLIER=1
# Sandbox mode for running jobs: none | restricted | container.
# 'container' is the only mode that isolates the filesystem — see
# docs/TRUST-AND-SECURITY.md. Use it for any untrusted buyers.
AGENTGRID_SANDBOX=none
# Container sandbox settings (only used when AGENTGRID_SANDBOX=container).
AGENTGRID_CONTAINER_IMAGE=agentgrid-worker
AGENTGRID_CONTAINER_MEMORY=2g
AGENTGRID_CONTAINER_CPUS=2
AGENTGRID_CONTAINER_NETWORK=bridge
